<root BTCPP_format="4" main_tree_to_execute="MainTree">
	<include path="./bt_power_monitor_sub_tree.xml" />
	<BehaviorTree ID="MainTree">
		<Sequence>
			<RunOnce>
				<Sequence>
					<!-- Initialize any BB vars needing initial values -->
					<Script code=" run_tools:=false " />
					<Script code=" tool_running:=false " />

					<Script code=" antenna_state_cur:='none' " />
					<Script code=" antenna_state_req:='none' " />

					<Script code=" pending_ui_input:='' " />

					<Script code=" use_vad:=false " />

					<Script code=" next_tts:='' " />
					<Script code=" tts_buffer:='' " />
					<Script code=" ai_text_to_speak:='' " />

					<Script code=" ai_abort:=false " />
					<Script code=" prompt:='' " />

					<GetTimeNowAction now="{end_response_time}" />

					<!-- ================================================= -->
					<!-- Declare the tool calls to be exposed to the model -->
					<!-- ================================================= -->

					<ToolCallTimeAction command="init" />

					<!-- Probably not needed now that ToolCallAnalyzeCameraFrameAction works -->
					<!--ToolCallAnalyzeCameraFrameAction command="init" /-->

					<!-- Requires fix from https://github.com/vllm-project/vllm/pull/41459
						 to allow images to be returned in tool call results -->
					<ToolCallGetCameraFrameAction command="init" />

					<ToolCallGetPositionAction command="init" />

					<ToolCallDeclareAction tc_definition='\{
        				"type": "function",
        				"function": {
            				"name": "move_to_absolute",
            				"description": "Use this tool to move the robot to a specified absolute position and then turn to the specified yaw orientation.  Returns a result property specifying one of: success, failed.  On failure the overall tool call sequence must be aborted. ",
							"parameters": {
								"type": "object",
								"properties": {
									"position_and_orientation": {
										"type": "object",
										"description": "The exact spatial placement coordinates and rotational yaw angle.",
										"properties": {
											"x": {
												"type": "number",
												"description": "The x-axis coordinate position in meter."
											},
											"y": {
												"type": "number",
												"description": "The y-axis coordinate position in meters."
											},
											"yaw": {
												"type": "number",
												"description": "Ending yaw after moving to the position.  The yaw is rotational angle around the z-axis (vertical) in degrees in the range [-180, 180] where an increase in yaw corresponds to turning left and vice versa."
											}
										},
										"required": ["x", "y", "yaw"]
									}
								},
								"required": ["position_and_orientation"]
							}
						}
					\}' />

					<ToolCallDeclareAction tc_definition='\{
        				"type": "function",
        				"function": {
            				"name": "move_to_relative",
            				"description": "Use this tool to move the robot by specifying a distance and heading change.  When asked to rotate to a specific heading, you should use the move_to_relative tool by first getting the current yaw, and then calculating the heading change needed to achieve the desired heading.  Returns a result property specifying one of:  success, failed.  On failure the overall tool call sequence must be aborted. ",
							"parameters": {
								"type": "object",
								"properties": {
									"movement_params": {
										"type": "object",
										"description": "The distance and change in heading.",
										"properties": {
											"distance": {
												"description": "Distance to move in meters",
												"type": "number"
											},
											"heading": {
												"description": "Change in current heading angle in the range [-180, 180] where an increase in yaw corresponds to turning left and vice versa. ",
												"type": "number"
											}
										},
										"required": ["distance", "heading"]
									}
								},
								"required": ["movement_params"]
							}
						}
					\}' />

					<ToolCallDeclareAction tc_definition='\{
        				"type": "function",
        				"function": {
            				"name": "spin_in_place",
            				"description": "Use this tool to rotate the robot by relative angle.  Do not use for turning to a specific heading.    Returns a result property specifying one of:  successm failed.  On failure the overall tool call sequence must be aborted. ",
							"parameters": {
								"type": "object",
								"properties": {
									"spin_params": {
										"type": "object",
										"description": "These control the amount and rate of spin.",
										"properties": {
											"angle": {
												"description": "Amount to rotate in degrees.  Positive values turn left and vice versa. Range [-720, 720]",
												"type": "number"
											},
											"rate": {
												"description": "Rate of turn in radians/second, range [0.2, 0.7].  If not instructed otherwise, use 0.5 for the rate.",
												"type": "number"
											}
										},
										"required": ["angle", "rate"]
									}
								},
								"required": ["spin_params"]
							}
						}
					\}' />

					<ToolCallDeclareAction tc_definition='\{
        				"type": "function",
        				"function": {
            				"name": "get_map_locations",
            				"description": "Use this tool to get a list of specific x,y,yaw locations you can move to.  Use this tool when asked for the room map location for a place. ",
							"returns": "A JSON array of objects each specifying:  location_name,x,y,yaw"
						}
					\}' />

					<ToolCallDeclareAction tc_definition='\{
        				"type": "function",
        				"function": {
            				"name": "speak",
            				"description": "Use this tool to speak using TTS prior to the final prompt result.  For example, use this during multi-step tool calls.  Dont use this for the final result since that result is always spoken",
							"parameters": {
                				"type": "object",
								"properties": {
                					"text_to_say": {
                    					"type": "string",
                    					"description": "The text to be spoken" }
								},
                				"required": ["text_to_say"]
							}
						}
					\}' />

					<ToolCallDeclareAction tc_definition='\{
        				"type": "function",
        				"function": {
            				"name": "ask_question",
            				"description": "Use this tool to ask the user a question and get there response.",
							"parameters": {
                				"type": "object",
								"properties": {
                					"question": {
                    					"type": "string",
                    					"description": "The text to ask the user"}
								},
                				"required": ["question"]
							},
							"returns": "Text string containing the user response"
						}
					\}' />
										
					<!-- Allow the system prompt to be replace or appended-to by command line args -->
					<IfThenElse>
						<TextCompareAction text="{def_value_1}" ck_for="" />
						<SetBlackboard output_key="system_prompt" value="You are a robot called elsabot (pronounced as elsuh-bot) but you
							should accept any name someone calls you.  You are also a helpful assistant. Your AI model is the Gemma 4,
							with 26 billion parameters.	You use Faster-Whisper for speech-to-text, Piper for text-to-speech, and Openwakeword
							for wake word detection and run on a Jetson Orin AGX computer. Respond only in plain text without narration.
							Do not use asterisks (*) for actions. Do not describe actions.	Only use 'face' emojis as a secondary way to express
							emotions. Keep your responses concise and don't make assumptions. You can be fun, witty, and amusing. Use the 'speak' tool to announce your intentions before taking a major action. For example, if you are about to move to a new location, say: 'I'm heading to...'   Don't over-explain your actions."/>
						<SetBlackboard output_key="system_prompt" value="{def_value_1}" />
					</IfThenElse>
					<IfThenElse>
						<TextCompareAction text="{def_value_2}" ck_for="" />
						<LogAction level="info" msg="No prompt modifier specified" />
						<Script code=" system_prompt:= system_prompt + def_value_2 " />
					</IfThenElse>

					<LogAction level="info" msg="Using system prompt: " arg1="{system_prompt}" />
				</Sequence>
			</RunOnce>

			<Parallel>
				<!-- Use a parallel node to monitor the power status -->
				<KeepRunningUntilFailure>
					<SubTree ID="PowerMonitorSubTree" _autoremap="true"/>
				</KeepRunningUntilFailure>

				<!-- =======================================================================================-->
				<!-- =======================================================================================-->
				<!-- =======================================================================================-->

				<!-- Use a parallel node to get user input from speech and pass to the LLM.  Also receives
					 tool calls from the mode and passed to a separate parallel node for execution. -->
				<KeepRunningUntilFailure>
					<ForceSuccess>
						<Sequence>

							<!-- ============================== -->
							<!-- Get a new prompt from the user -->
							<!-- ============================== -->

							<Fallback>
								<!-- Re-init these on every pass -->
								<ForceFailure>
									<Sequence>
										<Script code=" run_tools:=false " />
										<Script code=" tool_call_result:='' " />
										<Script code=" prompt:='' " />
									</Sequence>										
								</ForceFailure>								

								<!-- Wait for TTS to finish playing out.  After finishing, enable VAD for a specified duration -->
								<ForceFailure>
									<Sequence>
										<IfThenElse>
											<Fallback>
												<!-- TTS is active if text buffered or TTS being processed/played -->
												<Precondition if="tts_buffer=='' && next_tts==''" else="SUCCESS">
													<TTSActiveAction inactive_wait_timeout_sec="0.0" result="{tts_is_active}" return_on_active="SUCCESS" />
												</Precondition>													
											</Fallback>

											<!-- TTS is active -->
											<Sequence>
												<Script code=" antenna_state_req:='model_active' " />
												<GetTimeNowAction now="{end_response_time}" />
												<LogAction level="debug" msg="TTS active" />
											</Sequence>			

											<!-- TTS not active -->								
											<Sequence>
												<!-- Only allow VAD to trigger STT if speech occurs within N second of model output -->
												<IfThenElse>
													<TimeSinceAction time_point="{end_response_time}" comparison="less" duration_sec="10" />
													<Sequence>
														<Script code=" use_vad:=true " />
														<Script code=" antenna_state_req:='waiting_for_user_vad' " />
													</Sequence>
													<Sequence>													
														<Script code=" use_vad:=false " />
														<Script code=" antenna_state_req:='waiting_for_user' " />
													</Sequence>													
												</IfThenElse>												
											</Sequence>											
										</IfThenElse>
									</Sequence>										
								</ForceFailure>

								<!-- Also look for prompt input via the UI input topic (you can use the input_text.sh script for this)	-->
								<Fallback>
									<Precondition if="pending_ui_input !=''" else="FAILURE">
										<Sequence>
											<LogAction level="info" msg="Using pending ui input" arg1="{pending_ui_input}" />
											<Script code=" prompt=pending_ui_input; pending_ui_input='' " />
										</Sequence>											
									</Precondition>
									<UIInputAction action="ck_changed" property="text_input" value="{prompt}"/>
								</Fallback>									

								<!-- Look for either VAD or a wakeword trigger and enable speech-to-text if either occurred -->
								<Sequence>
									<Fallback>
										<Sequence>
											<Precondition if="use_vad == true" else="FAILURE">
												<Sequence>
													<LogAction level="debug" msg="VAD enabled" />
													<VoiceDetectedAction />
													<Script code=" speech_to_text_delay:=-2.0 " />
												</Sequence>
											</Precondition>
										</Sequence>							
										<Sequence>
											<WakeWordDetectedAction since_sec="1.0" />
											<Script code=" speech_to_text_delay:=0.5 " />
										</Sequence>							
									</Fallback>
									<PauseAudioAction stream_type="fg" />

									<Script code=" antenna_state_req:='listening' " />
									<SpeechToTextAction text="{prompt}" max_speech_duration="25"
														start_delay="{speech_to_text_delay}"
														pre_speech_timeout="5" post_speech_timeout="2" />
								</Sequence>							
							</Fallback>

							<!-- ================================== -->
							<!-- Process the prompt using the model -->														
							<!-- ================================== -->

							<LogAction level="info" msg="Using prompt: " arg1="{prompt}" />

							<Script code=" ai_text_to_speak:='' " />
							<Script code=" antenna_state_req:='waiting_for_user' " />

							<!-- Resume current audio playback (if any) if TTS is empty.  In that case processing
							     stops at this point -->
							<Inverter>
								<Sequence>
									<TextCompareAction text="{prompt}" ck_for="" />
									<ResumeAudioAction stream_type="fg" />
								</Sequence>
							</Inverter>

							<!-- The new input will be passed to the model so cancel any TTS being spoken now and resume
								 the pause done above. -->
							<CancelAudioAction req_id="all" />
							<ResumeAudioAction stream_type="fg" />

							<Script code=" antenna_state_req:='model_active' " />

							<!-- Call AIAction node until it is finished -->
							<ReactiveSequence>
								<!-- Buffer any new text generated by the last AIAction tick.  See comments
								     below where TextToSpeechAction is used. -->
								<Script code=" tts_buffer+=ai_text_to_speak; ai_text_to_speak='' " />

								<!-- Enable the tool call execution sequence in case any generated by the mode. -->
								<Script code=" run_tools:=true " />
								<Script code=" ai_abort:=false " />

								<!-- If wake word spoken while processing the AI request, then cancel the request
									 and any TTS triggered by the model -->

								<ForceSuccess>
									<Sequence>
										<Fallback>
											<!--VoiceDetectedAction /-->
											<WakeWordDetectedAction since_sec="1.0" />
											<!-- Also look for prompt input via the UI input topic (you can use the input_text.sh script for this)	-->
											<Sequence>
												<!-- SUCCESS if changed (always returns most recent value)-->
												<UIInputAction action="ck_changed" property="text_input" value="{temp_ui_input}"/>
												<Script code=" pending_ui_input=temp_ui_input " />
											</Sequence>												
										</Fallback>

										<Script code=" prompt:='cancel' " />
										<Script code=" ai_abort:=true; run_tools:=false " />
										<Script code=" tts_buffer:=''; ai_text_to_speak:='' " />
										<CancelAudioAction req_id="all" />
										<LogAction level="info" msg="Wake word detected during AIAction, cancelling AIAction" />
									</Sequence>
								</ForceSuccess>

								<AIAction prompt="{prompt}" abort="{ai_abort}" result="{ai_text_to_speak}" tool_call_name="{tool_call_name}"
												tool_call_args="{tool_call_args}" tool_call_result="{tool_call_result}"
												tool_call_timeout_sec="180" system_prompt="{system_prompt}"/>
							</ReactiveSequence>

							<!-- Buffer any new text generated by the final AIAction tick.  See comments
							     below where TextToSpeechAction is used. -->
							<Script code=" tts_buffer+=ai_text_to_speak; ai_text_to_speak='' " />

							<GetTimeNowAction now="{end_response_time}" />
						</Sequence>
					</ForceSuccess>
				</KeepRunningUntilFailure>

				<!-- =======================================================================================-->
				<!-- =======================================================================================-->
				<!-- =======================================================================================-->

				<!-- Use a parallel node to execute tool calls from the model.
					 The Keep running and force success are used to keep the sequence running forever. -->
				<KeepRunningUntilFailure>
					<ForceSuccess>
						<ReactiveSequence>
							<!-- This will interrupt a running tool when run_tools is set to 'n'-->
							<Precondition if="run_tools==false" else="SUCCESS">
								<ForceFailure>
									<Sequence>
										<Precondition if="tool_running==true" else="SUCCESS">
											<Sequence>
												<LogAction level="info" msg="Stopping current tool" />
												<Script code=" tool_running:=false " />
											</Sequence>												
										</Precondition>											
									</Sequence>										
								</ForceFailure>
							</Precondition>

							<!-- This runs a requested tool if any -->
							<Fallback>
								<Sequence>
									<Sequence>
										<Script code=" tool_running:=true " />
										<Script code=" running_tool:=tool_call_name " />
										<Script code=" tool_call_name:='' " />

										<Inverter>
											<TextCompareAction text="{running_tool}" ck_for="" />
										</Inverter>

										<LogAction level="info" msg="Running tool: " arg1="{running_tool}" />

										<Switch6 variable="{running_tool}" case_1="get_local_date_and_time"
												case_2="analyze_camera_frame" case_3="speak" case_4="get_robot_position"
												case_5="move_to_absolute" case_6="move_to_relative" >
											<ToolCallTimeAction command="run" args_json="{tool_call_args}" result_json="{tool_call_result}" />
											<SubTree ID="AnalyzeCameraFrame" _autoremap="true"/>
											<Sequence>
												<SubTree ID="SayText" _autoremap="true" />
											</Sequence>
											<ToolCallGetPositionAction command="run" result_json="{tool_call_result}"/>
											<SubTree ID="MoveToAbsolute" _autoremap="true" />
											<SubTree ID="MoveToRelative" _autoremap="true" />

											<Switch4 variable="{running_tool}" case_1="ask_question" case_2="get_camera_frame"
													case_3="get_map_locations" case_4="spin_in_place" >
												<SubTree ID="AskQuestionAndGetResponse" _autoremap="true" />
												<SubTree ID="GetCameraFrame" _autoremap="true" />

												<!-- get_locations -->
												<!-- Fix - get from a file -->
												<Sequence>
													<SetBlackboard output_key="tool_call_result" value='[{"location": "office tv",
																"x": -0.29, "y": 0.101, "yaw": 180.0},{"location": "playroom tv",
																"x": -4.48, "y": 0.143, "yaw": 0.0},
													{"location": "robot home", "x": 0.55, "y": -0.22, "yaw": 74.0}]'/>
												</Sequence>

												<SubTree ID="SpinInPlace" _autoremap="true" />

												<!-- Unrecognized tool -->
												<ForceFailure>
													<Sequence>
														<LogAction level="error" msg="Unrecognized tool call" arg1="{running_tool}" />
														<Script code=" tool_call_result:='{&quot;result&quot;: &quot;failed, unrecognized tool call&quot;}'" />
													</Sequence>												
												</ForceFailure>											
											</Switch4>											
										</Switch6>

									</Sequence>					
									<Script code=" tool_running:=false " />
									<LogAction level="info" msg="Finished run sequence" />
								</Sequence>						

								<!-- Clear running flag on failure -->
								<Script code=" tool_running:=false " />
							</Fallback>								
						</ReactiveSequence>
					</ForceSuccess>
				</KeepRunningUntilFailure>

				<!-- =======================================================================================-->
				<!-- =======================================================================================-->
				<!-- =======================================================================================-->

				<!-- Use a separate parallel node to manage the antenna state -->
				<KeepRunningUntilFailure>
					<ForceSuccess>
						<Sequence>
							<Precondition if="antenna_state_req != antenna_state_cur" else="SUCCESS">
								<Sequence>
									<LogAction level="info" msg="New antenna state" arg1="{antenna_state_req}" />
									<Precondition if="antenna_state_req == 'waiting_for_user'" else="SUCCESS">
										<Sequence>
											<Script code=" antenna_state_cur:='waiting_for_user' " />
											<AntennaAction rate="2" intensity="100" left_blink_pattern="10100000" right_blink_pattern="00001010" />
										</Sequence>											
									</Precondition>
									<Precondition if="antenna_state_req == 'waiting_for_user_vad'" else="SUCCESS">
										<Sequence>
											<Script code=" antenna_state_cur:='waiting_for_user_vad' " />
											<AntennaAction rate="2" intensity="100" left_blink_pattern="111110" right_blink_pattern="111110" />
										</Sequence>											
									</Precondition>
									<Precondition if="antenna_state_req == 'model_active'" else="SUCCESS">
										<Sequence>
											<Script code=" antenna_state_cur:='model_active' " />
											<AntennaAction rate="0" intensity="10" left_blink_pattern="0011" right_blink_pattern="1100" />
										</Sequence>											
									</Precondition>
									<Precondition if="antenna_state_req == 'listening'" else="SUCCESS">
										<Sequence>
											<Script code=" antenna_state_cur:='listening' " />
											<AntennaAction rate="3" intensity="100" left_blink_pattern="11111111"
												right_blink_pattern="11111111" />									
										</Sequence>											
									</Precondition>
								</Sequence>
							</Precondition>
						</Sequence>
					</ForceSuccess>
				</KeepRunningUntilFailure>

				<!-- =======================================================================================-->
				<!-- =======================================================================================-->
				<!-- =======================================================================================-->

				<!-- Use a separate parallel node to issue TTS requests. This is needed since the text to speak can be
					 generated in chunks by the AIAction node and since the TextToSpeechAction node does not complete
					 in one tick.  For example, the AIAction node may output a text fragment and then other in the next
					 tick.  If the text isn't buffered, then the first fragment might be lost (blackboard variable
					 overwritten). 
					 
					 Previously, the TextToSpeechAction node was place in the ReactiveSequence where the AIAction node
					 runs.  That actually worked until TextToSpeechAction was refactored to use Behavortree.ROS
					 as a base layer for the tree.  The previous implementation blocked until the current text was
					 sent.  As such, it wasn't possible for the AIAction node to overrun the outputting of the text.
				-->
				<KeepRunningUntilFailure>
					<ForceSuccess>
						<Sequence>
							<LogAction level="debug" msg="TTS loop, tts_buffer: " arg1="{tts_buffer}" />
							<LogAction level="debug" msg="TTS loop, next_tts:" arg1="{tts_buffer}" />
							<Script code=" next_tts=tts_buffer; tts_buffer='' " />
							<Precondition if="next_tts != ''" else="SUCCESS">
								<TextToSpeechAction text="{next_tts}" />
							</Precondition>								
						</Sequence>										
					</ForceSuccess>										
				</KeepRunningUntilFailure>
			</Parallel>
		</Sequence>			
	</BehaviorTree>

	<BehaviorTree ID="GetCameraFrame">
        <Sequence>
			<GetCameraFrameAction base64_image="{b64_image}" />
			<PlayAudioFileAction file_path="/robot_ws/audio_files/camera_shutter.mp3" stream_type="bg" req_id="3" />
			<ToolCallGetCameraFrameAction command="run" base64_image="{b64_image}" result_json="{tool_call_result}" />
		</Sequence>
    </BehaviorTree>

	<!-- May not be needed now that images can be returned in tool calls-->
	<BehaviorTree ID="AnalyzeCameraFrame">
        <Sequence>
			<GetCameraFrameAction base64_image="{b64_image}" />
			<PlayAudioFileAction file_path="/robot_ws/audio_files/camera_shutter.mp3" stream_type="bg" req_id="3" />
			<ToolCallAnalyzeCameraFrameAction command="run" args_json="{tool_call_args}" base64_image="{b64_image}"
			 result_json="{tool_call_result}" />
		</Sequence>
    </BehaviorTree>

	<BehaviorTree ID="SayText">
        <Sequence>
			<LogAction level="info" msg="SayText Subtree" arg1="{tool_call_args}" />
			<!-- Parse json containing text to say and store text in BB /-->
			<CopyJsonKeyValueIntoBBAction json_in="{tool_call_args}" json_key_pointer="/text_to_say" output="{text_to_speak}" />
			<Script code=" tts_buffer+=text_to_speak; text_to_speak='' " />
			<Script code=" tool_call_result:='{&quot;result&quot;: &quot;success&quot;}'" />
		</Sequence>
    </BehaviorTree>

	<BehaviorTree ID="MoveToAbsolute">
        <Sequence>
			<LogAction level="info" msg="MoveToAbsolute Subtree" arg1="{tool_call_args}" />
			<!-- Parse json containing position and store text in BB /-->
			<CopyJsonKeyValueIntoBBAction json_in="{tool_call_args}" json_key_pointer="/position_and_orientation" output="{move_to_goal}" />
			<IfThenElse>
				<Nav2NavigateAction goal="{move_to_goal}" />
				<Script code=" tool_call_result:='{&quot;result&quot;: &quot;success&quot;}'" />
				<Script code=" tool_call_result:='{&quot;result&quot;: &quot;failed&quot;}'" />
			</IfThenElse>
		</Sequence>
    </BehaviorTree>

	<BehaviorTree ID="MoveToRelative">
        <Sequence>
			<LogAction level="info" msg="MoveToRelative Subtree" arg1="{tool_call_args}" />
			<!-- Parse json containing position and store text in BB /-->
			<Fallback>
				<Sequence>
					<CopyJsonKeyValueIntoBBAction json_in="{tool_call_args}" json_key_pointer="/movement_params" output="{movement_params}" />
					<CopyJsonKeyValueIntoBBAction json_in="{movement_params}" json_key_pointer="/distance" output="{distance}" />
					<CopyJsonKeyValueIntoBBAction json_in="{movement_params}" json_key_pointer="/heading" output="{heading}" />
				</Sequence>
				<ForceFailure>
					<Sequence>
						<Script code=" tool_call_result:='{&quot;result&quot;: &quot;invalid_parameters&quot;}'" />
						<LogAction level="info" msg="MoveToRelative Subtree - failed, invalid params" />
					</Sequence>						
				</ForceFailure>
			</Fallback>
			<!-- Nav to otherwise -->
			<Sequence>
				<LogAction level="info" msg="MoveToRelative Subtree - using Nav2" />
				<IfThenElse>
					<Nav2NavigateAction goal_relative="{movement_params}" />
					<Script code=" tool_call_result:='{&quot;result&quot;: &quot;success&quot;}'" />
					<Script code=" tool_call_result:='{&quot;result&quot;: &quot;failed&quot;}'" />
				</IfThenElse>
			</Sequence>					
		</Sequence>
    </BehaviorTree>

	<BehaviorTree ID="SpinInPlace">
        <Sequence>
			<LogAction level="info" msg="SpinInPlace Subtree" arg1="{tool_call_args}" />

			<!-- Parse json containing param and store in BB /-->
			<Fallback>
				<Sequence>
					<CopyJsonKeyValueIntoBBAction json_in="{tool_call_args}" json_key_pointer="/spin_params" output="{spin_params}" />
					<CopyJsonKeyValueIntoBBAction json_in="{spin_params}" json_key_pointer="/angle" output="{angle}" />
					<CopyJsonKeyValueIntoBBAction json_in="{spin_params}" json_key_pointer="/rate" output="{rate}" />
					<Precondition if="rate>0.5" else="SUCCESS">
						<ForceFailure>
							<LogAction level="info" msg="Invalid rate for spin tool call" />
						</ForceFailure>
					</Precondition>
				</Sequence>
				<ForceFailure>
					<Sequence>
						<Script code=" tool_call_result:='{&quot;result&quot;: &quot;invalid_parameters&quot;}'" />
						<LogAction level="info" msg="SpinInPlace Subtree - failed, invalid params" />
					</Sequence>						
				</ForceFailure>
			</Fallback>

			<IfThenElse>
				<RobotSpin angle="{angle}" velocity="{rate}" />
				<Script code=" tool_call_result:='{&quot;result&quot;: &quot;success&quot;}'" />
				<Script code=" tool_call_result:='{&quot;result&quot;: &quot;failed&quot;}'" />
			</IfThenElse>
		</Sequence>
    </BehaviorTree>

	<BehaviorTree ID="AskQuestionAndGetResponse">
        <Sequence>
			<LogAction level="info" msg="AskQuestionAndGetResponse Subtree" arg1="{tool_call_args}" />
			<!-- Parse json containing question to ask and store text in BB /-->
			<CopyJsonKeyValueIntoBBAction json_in="{tool_call_args}" json_key_pointer="/question" output="{text_to_speak}" />

			<Script code=" tts_buffer+=text_to_speak; text_to_speak='' " />

			<!-- Give some time for TTS to become active before waiting for it to finish -->
			<Delay delay_msec="500">
				<!-- Wait for TTS to finish, best effort -->
				<ForceSuccess>
					<!-- TTS is active if text buffered or TTS being processed/played -->
					<Precondition if="tts_buffer=='' && next_tts==''" else="SUCCESS">
						<TTSActiveAction inactive_wait_timeout_sec="30.0" result="{tts_is_active}" return_on_active="SUCCESS" />
					</Precondition>						
				</ForceSuccess>		
			</Delay>

			<Script code=" antenna_state_req:='listening' " />
			<Script code=" said:='' " />
		
			<ForceSuccess>
				<SpeechToTextAction text="{said}" max_speech_duration="25" start_delay="0.5" pre_speech_timeout="10" post_speech_timeout="2" />
			</ForceSuccess>

			<Precondition if="said==''" else="SUCCESS">
				<Script code=" said:='<Nothing said>' " />
			</Precondition>

			<Script code=" tool_call_result:='{&quot;result&quot;: &quot;placeholder&quot;}'" />
			<CopyBBValueIntoJsonKeyValueAction json_in_out="{tool_call_result}" json_key_pointer="/result" value="{said}" />
			<Script code=" said:='' " />
			<Script code=" antenna_state_req:='model_active' " />
		</Sequence>
    </BehaviorTree>

</root>

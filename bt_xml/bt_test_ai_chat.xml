<root main_tree_to_execute="MainTree">
	<BehaviorTree ID="MainTree">
		<KeepRunningUntilFailure>
			<ForceSuccess>
				<Sequence>
					<Fallback>
						<Sequence>
							<VoiceDetected />
							<SetBlackboard output_key="speech_to_text_delay" value="-2.0" />
						</Sequence>							
						<Sequence>
							<WakeWordDetected since_sec="1.0" />
							<SetBlackboard output_key="speech_to_text_delay" value="0.5" />
						</Sequence>							
					</Fallback>
 					<PauseAudioAction stream_type="fg" />

       				<AntennaAction rate="3" intensity="100" left_blink_pattern="11111111" right_blink_pattern="11111111" />

					<SpeechToTextActionClient text="{said}" delay="{speech_to_text_delay}" />
					<LogAction level="info" msg="Using prompt: " arg1="{said}" />
					<SetBlackboard output_key="text_to_speak" value="" />
	
       				<AntennaAction rate="2" intensity="100" left_blink_pattern="10100000" right_blink_pattern="00001010" />

					<!-- Resume current audio playback (if any) if TTS is empty -->
					<Inverter>
						<Sequence>
							<TextCompareAction text="{said}" ck_for="" />
							<ResumeAudioAction stream_type="fg" />
						</Sequence>
					</Inverter>

 					<CancelAudioAction req_id="all" />
					<ResumeAudioAction stream_type="fg" />

					<AntennaAction rate="0" intensity="10" left_blink_pattern="01" right_blink_pattern="10" />

					<!-- Call AIModelRequest until is finished -->
					<ReactiveSequence>
						<!-- If wake work spoken while processing the AI request, then cancel it and any TTS from it -->
						<Inverter>
							<Sequence>
								<Fallback>
									<VoiceDetected />
									<WakeWordDetected since_sec="1.0" />
								</Fallback>	
								<CancelAudioAction req_id="all" />
								<SetBlackboard output_key="text_to_speak" value="" />
							</Sequence>
						</Inverter>

						<!-- Revert to normal antenna pattern on first speech output -->
						<ForceSuccess>
							<Sequence>
								<Inverter>
									<TextCompareAction text="{text_to_speak}" ck_for="" />
								</Inverter>
			       				<AntennaAction rate="2" intensity="100" left_blink_pattern="10100000" right_blink_pattern="00001010" />
							</Sequence>
						</ForceSuccess>							

						<!-- On each pass try to play output from the previous update-->
						<TextToSpeechAction text="{text_to_speak}" />
						<SetBlackboard output_key="text_to_speak" value="" />
  						<AIChatAction prompt="{said}" result="{text_to_speak}" system_prompt= 
							"You are a robot called elsabot and a helpful assistant. Respond only in plain text. 
							Write only dialogue, no narration.	Do not use asterisks (*) for actions. 
							Use emojis when appropriate to express yourself.
							You can be silly at times to amuse little kids."/>
					</ReactiveSequence>
					<!-- Say the remaining part of the response if any -->
					<TextToSpeechAction text="{text_to_speak}" />
       				<AntennaAction rate="2" intensity="100" left_blink_pattern="10100000" right_blink_pattern="00001010" />
				</Sequence>
			</ForceSuccess>
		</KeepRunningUntilFailure>
	</BehaviorTree>
</root>

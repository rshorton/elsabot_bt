<root BTCPP_format="4" main_tree_to_execute = "MainTree">
    <BehaviorTree ID="MainTree">
        <Repeat num_cycles="3">
            <Sequence>
                <SetBlackboard output_key="Goal_a" value="0,0,180.0" />
                <SetBlackboard output_key="Goal_b" value="0,0,90.0" />
                <Sequence>
                    <SubTree ID="MoveRobot" target="{Goal_a}" _autoremap="true"/>
                    <TextToSpeechAction text="I'm at goal A" />
                    <SubTree ID="MoveRobot" target="{Goal_b}" _autoremap="true"/>
                    <TextToSpeechAction text="I'm at goal B" />
                </Sequence>
            </Sequence>
        </Repeat>
    </BehaviorTree>

    <BehaviorTree ID="MoveRobot">
        <Sequence name="SetGoal">
            <Nav2NavigateAction goal="{target}" />
        </Sequence>
    </BehaviorTree>
</root>

<root BTCPP_format="4" main_tree_to_execute="MainTree">
	<BehaviorTree ID="MainTree">
        <KeepRunningUntilFailure>
            <ForceSuccess>
                <Sequence>
                    <Fallback>
                        <Sequence>
                            <VoiceDetectedAction />
                            <SetBlackboard output_key="speech_to_text_delay" value="-2.0" />
                        </Sequence>							
                        <Sequence>
                            <WakeWordDetectedAction since_sec="1.0" />
                            <SetBlackboard output_key="speech_to_text_delay" value="0.5" />
                        </Sequence>							
                    </Fallback>
                    <SpeechToTextAction text="{said}" start_delay="{speech_to_text_delay}" />
                    <TextToSpeechAction text="{said}" />
                </Sequence>
            </ForceSuccess>
        </KeepRunningUntilFailure>
    </BehaviorTree>
</root>
